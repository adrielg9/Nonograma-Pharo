stream close. 	men:= Alerta new.	men mensaje: 'Se exportó exitosamente'.	].	! !----SNAPSHOT----2023-11-26T19:01:12.651-03:00 Nueva imagen.image priorSource: 183508!----SNAPSHOT----2023-11-26T19:02:32.192-03:00 Nueva imagen.image priorSource: 184381!----QUIT----2023-11-26T19:02:34.083-03:00 Nueva imagen.image priorSource: 184468!Object subclass: #Juego	instanceVariableNames: '' 	classVariableNames: ''	package: 'Nonograma'!!Juego class methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 19:04'!iniciarPTitulo new.! !----SNAPSHOT----2023-11-26T19:49:32.489-03:00 Nueva imagen.image priorSource: 184555!----QUIT----2023-11-26T19:49:37.858-03:00 Nueva imagen.image priorSource: 184852!----SNAPSHOT----2023-11-26T20:00:39.863-03:00 Nonograma.image priorSource: 184939!----SNAPSHOT----2023-11-26T20:01:19.502-03:00 Nonograma.image priorSource: 185022!----QUIT----2023-11-26T20:01:28.927-03:00 Nonograma.image priorSource: 185106!