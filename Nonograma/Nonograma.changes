_iz new.ref_izquierda crearTablero: unTamaño ancho: (unAncho /2) ceiling altura: unAlto ceiling."creamos la ventana para poner todo lo demas dentro y posicionamos lo que creamos"ventana:= SystemWindow new.ventana extent: (tablero extent)+((ref_izquierda width)@(ref_superior height))+(100@100).ventana addMorph: tablero.ventana addMorph: ref_izquierda.ventana addMorph: ref_superior."Posicionamos los tableros"tablero position: ventana position + (50@50) + ((ref_izquierda width)@(ref_superior height)).ref_izquierda position: ventana position + (50@50) + (0@(ref_superior height)).ref_superior position: ventana position + (50@50) + ((ref_izquierda width)@0)."Abrimos la ventana en el mundo"ventana setLabel: 'Nonograma'.ventana openInWorld.! !!Nivel methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/25/2023 21:04' prior: 33612149!editor: unTamaño ancho: unAncho alto: unAlto "Creamos el tablero del tamaño"tablero:= Nonograma new.tablero crearTablero: unTamaño  ancho: unAncho  altura: unAlto ."creamos la ventana para poner todo lo demas dentro y posicionamos lo que creamos"ventana:= SystemWindow new.ventana extent: (tablero extent)+(100@100).ventana addMorph: tablero."Posicionamos los tableros"tablero position: ventana position + (50@50)."Abrimos la ventana en el mundo"ventana setLabel: 'Crea tu propio Nonograma'.ventana openInWorld.! !!Nivel methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/25/2023 21:14' prior: 33613387!editor: unTamaño ancho: unAncho alto: unAlto "Creamos el tablero del tamaño"tablero:= Nonograma new.tablero crearTablero: unTamaño  ancho: unAncho  altura: unAlto ."creamos la ventana para poner todo lo demas dentro y posicionamos lo que creamos"ventana:= SystemWindow new.ventana extent: (tablero extent)+(100@100).ventana addMorph: tablero."creamos botones para reinicio y exportacion"clear:= BotonComun new.clear label: 'Limpiar'.export := BotonComun new.export label: 'Exportar'.