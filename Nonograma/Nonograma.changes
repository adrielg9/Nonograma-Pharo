            request: 'Ingrese un ancho para el tablero'		            initialAnswer: ''		            title: 'Configurando el editor'.	[ (ancho = '')or: [ ancho = '0' ] ] whileTrue: [		ancho := UIManager default			            request: 'Por favor ingrese un ancho valido'			            initialAnswer: ''			            title: 'Configurando el editor' ].ancho ifNil: [ ^nil ].alto := UIManager default		            request: 'Ingrese un alto para el tablero'		            initialAnswer: ''		            title: 'Configurando el editor'.	[ (alto = '')or: [ alto = '0' ] ] whileTrue: [		alto := UIManager default			            request: 'Por favor ingrese un alto valido'			            initialAnswer: ''			            title: 'Configurando el editor' ].		alto ifNil: [ ^nil ].				tamaño := UIManager default		            request: 'Ingrese un tamaño para las casillas del tablero'		            initialAnswer: ''		            title: 'Configurando el editor'.	[ (tamaño = '')or: [ tamaño = '0' ] ] whileTrue: [		tamaño := UIManager default			            request: 'Por favor ingrese un tamaño valido'			            initialAnswer: ''			            title: 'Configurando el editor' ].		tamaño ifNotNil:[	self close.	ancho:= ancho asInteger. 	alto:= alto asInteger.	tamaño:= tamaño asInteger.	nivel:= Nivel new.	nivel editor: tamaño ancho: ancho  alto: alto. 	]! !----SNAPSHOT----2023-11-26T17:18:39.007-03:00 Nueva imagen.image priorSource: 161385!!SelecNiv methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 17:24'!regresar ventana close.PTitulo new.! !!SelecNiv methodsFor: 'initialization' stamp: 'EscalanteThiago 11/26/2023 17:24' prior: 33695489!initialize |ancho alto|botones:= Array new: 9.ventana:= SystemWindow new.1 to: 9 do: [ :x | 	botones at:x put:(BotonComun new). 	(botones at:x)label: 'Nivel ', (x asString).	ventana addMorph: (botones at:x). 	(botones at:x) mouseAction: [self seleccionar: x].	].ancho:= ((botones at:1