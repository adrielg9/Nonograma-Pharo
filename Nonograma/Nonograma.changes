ame stream |	object := self copiarMatriz.	fileName := UIManager default		            request: 'Ingrese un nombre para el archivo'		            initialAnswer: ''		            title: 'Nombre del archivo'.	[ fileName = '' ] whileTrue: [		fileName := UIManager default			            request: 'Por favor ingrese un nombre valido'			            initialAnswer: ''			            title: 'Nombre del archivo' ].fileName ifNotNil: [ 	fileName:= fileName, ',fuel'.	stream := fileName asFileReference binaryWriteStream.	FLSerializer serialize: object on: stream.	stream close. 	UIManager default alert: 'Se ha exportado correctamente' title: 'Exportacion exitosa'.	].	! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 11:53' prior: 33666541!exportar	| object fileName stream |	object := self copiarMatriz.	fileName := UIManager default		            request: 'Ingrese un nombre para el archivo'		            initialAnswer: ''		            title: 'Nombre del archivo'.	[ fileName = '' ] whileTrue: [		fileName := UIManager default			            request: 'Por favor ingrese un nombre valido'			            initialAnswer: ''			            title: 'Nombre del archivo' ].fileName ifNotNil: [ 	fileName:= fileName, '.fuel'.	stream := fileName asFileReference binaryWriteStream.	FLSerializer serialize: object on: stream.	stream close. 	UIManager default alert: 'Se ha exportado correctamente' title: 'Exportacion exitosa'.	].	! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 12:10' prior: 33618829!limpiar1 to: (cells numberOfColumns) do:[:i| 	1 to: (cells numberOfRows) do: [ :j|			((cells at: j at:i)isOn) ifTrue:[(cells at: j at:i)mouseDown: nil].		 ].	].! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 12:16'!completar1 to: (cells numberOfColumns) do:[:i| 	1 to: (cells numberOfRows) do: [ :j|			((matriz at:i at:j)= 1) ifTrue:[				((cells at:j at:i)i