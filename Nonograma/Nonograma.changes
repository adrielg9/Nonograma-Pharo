:= UIManager default chooseFullFileNameMatching: #('*.fuel').ruta ifNotNil:[		self close.		nivel:= Nivel new.		nivel crearNivel: (self abrir:ruta).	]! !----SNAPSHOT----2023-11-26T18:34:19.223-03:00 Nueva imagen.image priorSource: 174132!----SNAPSHOT----2023-11-26T18:34:23.552-03:00 Nueva imagen.image priorSource: 176451!----SNAPSHOT----2023-11-26T18:34:29.212-03:00 Nueva imagen.image priorSource: 176538!----SNAPSHOT----2023-11-26T18:34:34.873-03:00 Nueva imagen.image priorSource: 176625!SystemWindow subclass: #Alerta	instanceVariableNames: 'mensaje boton' 	classVariableNames: ''	package: 'Nonograma'!!Alerta methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 18:40'!initializesuper initialize.mensaje:= Cartel new.mensaje label:'' font: (StrikeFont familyName: 'Bitmap DejaVu Sans' size: 30).boton:= BotonComun new.boton label: 'Cerrar'.boton mouseAction: [ self close ].self addMorph: boton.! !!Alerta methodsFor: 'initialization' stamp: 'EscalanteThiago 11/26/2023 18:45' prior: 33731437!initializesuper initialize.mensaje:= Cartel new.mensaje label:'' font: (StrikeFont familyName: 'Bitmap DejaVu Sans' size: 30).self addMorph: mensaje.boton:= BotonComun new.boton label: 'Cerrar'.boton mouseAction: [ self close ].self addMorph: boton.self extent: (100@150)+ ((boton width)@((boton height)*2)).mensaje position: self position + (50@50).boton position: mensaje position + (0@(mensaje position))+ (0@50).! !!Alerta methodsFor: 'initialization' stamp: 'EscalanteThiago 11/26/2023 18:45' prior: 33731773!initializesuper initialize.mensaje:= Cartel new.mensaje label:'' font: (StrikeFont familyName: 'Bitmap DejaVu Sans' size: 30).self addMorph: mensaje.boton:= BotonComun new.boton label: 'Cerrar'.boton mouseAction: [ self close ].self addMorph: boton.self extent: (100@150)+ ((boton width)@((boton height)*2)).mensaje position: self position + (50@50).boton position: mensaje position + (0@(mensaje positio