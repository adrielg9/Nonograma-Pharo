 tamaño"tablero:= Nonograma new.tablero crearTablero: unTamaño  ancho: unAncho  altura: unAlto ."creamos botones para reinicio y exportacion"clear:= BotonComun new.clear label: 'Limpiar'.clear mouseAction: [ tablero limpiar ].export := BotonComun new.export label: 'Exportar'.export mouseAction: [ tablero exportar. ].export color: (Color fromHexString: '#a14347').volver := BotonComun new.volver label: 'Volver'.volver color: (Color fromHexString: '#5ba35f').volver mouseAction: [ self volver. ].ventana:= SystemWindow new.ventana extent: (tablero extent)+(150@100)+ ((clear width)@0).ventana addMorph: clear.ventana addMorph: export.ventana addMorph: volver.ventana addMorph: tablero."Posicionamos los tableros"tablero position: ventana position + (50@50).clear position: ventana position + (100@50) + ((tablero width)@0).export position: clear position + (0@20) + (0@(clear height)).volver position: export position + (0@20) + (0@(clear height))."Abrimos la ventana en el mundo"ventana setLabel: 'Crea tu propio Nonograma'.ventana openInWorld.! !!Nivel methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 15:30'!crearNivel: unTamaño ancho: unAncho alto: unAlto "Creamos el tablero del tamaño"tablero calcularPintadas.tablero crearTablero: unTamaño  ancho: unAncho  altura: unAlto ."Creamos la referencia superior"ref_superior:= Refer_sup new.ref_superior crearTablero: unTamaño ancho: unAncho altura: (unAlto / 2) ceiling."Creamos la referencia izquierda"ref_izquierda := Refer_iz new.ref_izquierda crearTablero: unTamaño ancho: (unAncho /2) ceiling altura: unAlto ceiling."creamos botones"clear:= BotonComun new.clear label: 'Limpiar'.clear mouseAction: [ tablero limpiar ].volver := BotonComun new.volver label: 'Volver'.volver color: (Color fromHexString: '#5ba35f').volver mouseAction: [ self regresar. ]."creamos la ventana para poner todo lo demas dentro y posicionamos lo que creamos"ventana:= SystemWindow new.ventana extent: (tablero extent)+((ref_izquierda width)@(ref_superior height))+(150@100)+((clear width)@0).ventana addMorph: tablero.ventana addMorph: ref_izquierda.ventana addMorph: ref_superior.ventana addMorph: clear.ventana addMorph: volver."Posicionamos los tableros"tablero position: ventana position + (50@50) + ((ref_izquierda width)@(ref_superior height)).clear position: tablero position + ((tablero width)@0) + (50@0).volver position: clear position + (0@(clear height)) + (0@20).ref_izquierda position: ventana position + (50@50) + (0@(ref_superior height)).ref_superior position: ventana position + (50@50) + ((ref_izquierda width)@0).(Truco resolver) ifTrue:[		resolver:= BotonComun new.		resolver color: (Color fromHexString: '#8347a6').		resolver label: 'Resolver'.		resolver mouseAction: [ tablero completar ].		ventana addMorph: resolver.		resolver position: volver position + (0@(clear height)) + (0@20).	]."Abrimos la ventana en el mundo"ventana setLabel: 'Nonograma'.ventana openInWorld.! !!Nivel methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 14:44'!crearNivel: unaMatriztablero:= Nonograma new.tablero matriz: unaMatriz.self crearNivel: (Truco size) ancho: (unaMatriz numberOfColumns) alto: (unaMatriz numberOfRows).ref_superior calcularReferencia: unaMatriz.ref_izquierda calcularReferencia: unaMatriz.! !BorderedMorph subclass: #Nonograma	instanceVariableNames: 'cells cont matriz pintadas'	classVariableNames: ''	package: 'Nonograma'!!Nonograma methodsFor: 'initialization' stamp: 'ThiagoEscalante 11/18/2023 22:33'!crearTablero: unTamaño ancho: unaAltura altura: unAncho| sampleCell width height |	sampleCell := NOCell new.	sampleCell setTamaño: unTamaño.	width := sampleCell width.	height := sampleCell height.	self bounds: (unTamaño @ unTamaño extent: (width * unaAltura) @ (height * unAncho) + (2 * self	borderWidth)).	cells := Array2D rows: unaAltura  columns: unAncho tabulate: [ :i :j | self newCellAt: i at:	j size: unTamaño]! !!Nonograma methodsFor: 'initialization' stamp: 'ThiagoEscalante 11/23/2023 20:34'!initialize 	super initialize.	cont:= 0.! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'ThiagoEscalante 11/23/2023 20:40'!aumentarcont:= cont + 1.! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/25/2023 22:43'!calcularPintadaspintadas:= 0.1 to: (matriz  numberOfRows) do:[:i| 	1 to: (matriz numberOfColumns) do: [ :j|			((matriz at: i at:j) = 1) ifTrue:[pintadas := pintadas + 1].		 ].	].Transcript show:'Pintadas:'; show: pintadas asString.! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 12:10'!limpiar1 to: (cells numberOfColumns) do:[:i| 	1 to: (cells numberOfRows) do: [ :j|			((cells at: j at:i)isOn) ifTrue:[(cells at: j at:i)mouseDown: nil].		 ].	].! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'ThiagoEscalante 11/23/2023 20:40'!disminuircont:= cont - 1.! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 12:47'!completarmatriz ifNotNil: [  	1 to: (cells numberOfColumns) do:[:i| 		1 to: (cells numberOfRows) do: [ :j|				((matriz at:i at:j)= 1) ifTrue:[					((cells at:j at:i)isOn) ifFalse: [							(cells at: j at:i)mouseDown: nil 					 	]. 					].			 ].		].	].! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/25/2023 22:18'!copiarMatriz|matriz|matriz:= Array2D rows:(cells numberOfColumns) columns:(cells numberOfRows).1 to: (matriz numberOfRows) do:[:i| 	1 to: (matriz numberOfColumns) do: [ :j|			((cells at: j at:i)isOn) ifTrue:[matriz at:i at:j put: 1].		 ].	].^matriz! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 18:49'!newCellAt: i at: j size: unTamaño| c origin men |	c := NOCell new.	c setTamaño: unTamaño.	origin := self innerBounds origin.	self addMorph: c.	c position: ((i - 1) * c width) @ ((j - 1) * c height) + origin.	c mouseAction: [ 		c isOn ifTrue: [ self disminuir] 		ifFalse: [ self aumentar].		c toggleState.		(pintadas = cont) ifTrue:[				(matriz=(self copiarMatriz))ifTrue:[						men:= Alerta new.						men mensaje: '!!!!Ganaste!!!!'.				]			]		].	^c! !!Nonograma methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 18:59'!exportar	| object fileName stream men |	object := self copiarMatriz.	fileName := UIManager default		            request: 'Ingrese un nombre para el archivo'		            initialAnswer: ''		            title: 'Nombre del archivo'.	[ fileName = '' ] whileTrue: [		fileName := UIManager default			            request: 'Por favor ingrese un nombre valido'			            initialAnswer: ''			            title: 'Nombre del archivo' ].fileName ifNotNil: [ 	fileName:= fileName, '.fuel'.	stream := fileName asFileReference binaryWriteStream.	FLSerializer serialize: object on: stream.	stream close. 	men:= Alerta new.	men mensaje: 'Se exportó exitosamente'.	].	! !!Nonograma methodsFor: 'accessing' stamp: 'EscalanteThiago 11/25/2023 22:38'!matriz: unaMatrizmatriz:= unaMatriz.! !SystemWindow subclass: #PTitulo	instanceVariableNames: 'jugar editor creditos titulo'	classVariableNames: ''	package: 'Nonograma'!!PTitulo methodsFor: 'initialization' stamp: 'EscalanteThiago 11/26/2023 16:49'!initializesuper initialize. Truco size: 25.Truco resolver: false.self crearElementos.self extent: (200@150) + (((jugar width)*3)@((jugar height)*2)).self posicionarElementos.self setLabel: 'Nonograma'.self openInWorld.! !!PTitulo methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 16:14'!posicionarElementosself addMorph: jugar. self addMorph: editor. self addMorph: creditos. self addMorph: titulo. jugar position: self position + (50@50) + (0@(jugar height)). editor position: jugar position +(50@0) + ((jugar width)@0).creditos position: editor position +(50@0) + ((jugar width)@0).titulo position: self position + (100@50) + ((jugar width)@0)! !!PTitulo methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 18:17'!crearElementosjugar := BotonComun new.jugar label: 'Jugar'.jugar mouseAction: [ self jugar ].editor := BotonComun new.editor label: 'Editor'.editor color: (Color fromHexString: '#a14347').editor mouseAction: [ self editor ].creditos := BotonComun new.creditos label: 'Creditos'.creditos color: (Color fromHexString: '#8347a6').creditos mouseAction: [ self creditos ].titulo:= Cartel new.titulo label: 'Nonograma UTN' font: (StrikeFont familyName: 'Bitmap DejaVu Sans' size: 35).! !!PTitulo methodsFor: 'accessing' stamp: 'EscalanteThiago 11/26/2023 17:03'!editor|ancho alto nivel tamaño|		ancho := UIManager default		            request: 'Ingrese un ancho para el tablero'		            initialAnswer: ''		            title: 'Configurando el editor'.	[ (ancho = '')or: [ ancho = '0' ] ] whileTrue: [		ancho := UIManager default			            request: 'Por favor ingrese un ancho valido'			            initialAnswer: ''			            title: 'Configurando el editor' ].ancho ifNil: [ ^nil ].alto := UIManager default		            request: 'Ingrese un alto para el tablero'		            initialAnswer: ''		            title: 'Configurando el editor'.	[ (alto = '')or: [ alto = '0' ] ] whileTrue: [		alto := UIManager default			            request: 'Por favor ingrese un alto valido'			            initialAnswer: ''			            title: 'Configurando el editor' ].		alto ifNil: [ ^nil ].				tamaño := UIManager default		            request: 'Ingrese un tamaño para las casillas del tablero'		            initialAnswer: ''		            title: 'Configurando el editor'.	[ (tamaño = '')or: [ tamaño = '0' ] ] whileTrue: [		tamaño := UIManager default			            request: 'Por favor ingrese un tamaño valido'			            initialAnswer: ''			            title: 'Configurando el editor' ].		