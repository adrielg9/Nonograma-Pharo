tents: unTexto font: (fuente ifNil: [StandardFonts buttonFont]).	label position: self center - (label extent // 2).	self addMorph: label.	label lock! !BorderedMorph subclass: #Refer_sup	instanceVariableNames: 'cells'	classVariableNames: ''	package: 'Nonograma'!!Refer_sup methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/25/2023 11:15'!calcularReferencia: unaMatriz|i j cont fila|j:= unaMatriz numberOfColumns.cont:= 0.[ j>0 ] whileTrue: [ 	Transcript show: 'col:' asString; show: j; cr.	i:= unaMatriz numberOfRows.	fila:= cells numberOfColumns.	[ i > 0 ] whileTrue: [ 		Transcript show: 'fila:' asString; show: i; cr.		((unaMatriz at:i at:j) = 1)ifTrue:[				cont:= cont + 1.			]ifFalse:[				(cont > 0)ifTrue:[					(cells at: j at: fila) label: cont asString.					cont:= 0.					fila:= fila -1.					].			].		i := i - 1	 ].		(cont > 0)ifTrue:[		(cells at: j at: fila) label: cont asString.		cont:= 0.		fila:= fila -1.		].		j:= j - 1	 ].! !!Refer_sup methodsFor: 'initialization' stamp: 'EscalanteThiago 11/24/2023 18:10'!crearTablero: unTamaño ancho: unaAltura altura: unAncho| sampleCell width height |	sampleCell := RefCell new.	sampleCell setTamaño: unTamaño.	width := sampleCell width.	height := sampleCell height.	self bounds: (unTamaño @ unTamaño extent: (width * unaAltura) @ (height * unAncho) + (2 * self	borderWidth)).	cells := Array2D rows: unaAltura  columns: unAncho tabulate: [ :i :j | self newCellAt: i at:	j size: unTamaño]! !!Refer_sup methodsFor: 'initialization' stamp: 'EscalanteThiago 11/24/2023 18:59'!initialize super initialize.self borderColor: (Color fromHexString: #a1a1a1)! !!Refer_sup methodsFor: 'accessing' stamp: 'EscalanteThiago 11/24/2023 18:55'!newCellAt: i at: j size: unTamaño"Create a cell for position (i,j) and add it to my on-screenrepresentation at the appropriate screen position. Answer thenew cell"| c origin |	c := RefCell new.	c setTamaño: unTamaño.		(i odd) 	ifTrue: [ 		c clara.		 ] 	ifFalse: [ 		c oscura.		 ].		origin := self innerBounds origin.	self addMorph: c.	c position: ((i - 1) * c width) @ ((j - 1) * c height) + origin.	^c! !!Refer_sup methodsFor: 'accessing' stamp: 'EscalanteThiago 11/24/2023 23:39'!cells^cells! !Refer_sup subclass: #Refer_iz	instanceVariableNames: ''	classVariableNames: ''	package: 'Nonograma'!!Refer_iz methodsFor: 'accessing' stamp: 'EscalanteThiago 11/24/2023 19:07'!newCellAt: i at: j size: unTamaño"Create a cell for position (i,j) and add it to my on-screenrepresentation at the appropriate screen position. Answer thenew cell"| c origin |	c := RefCell new.	c setTamaño: unTamaño.		(j odd) 	ifTrue: [ 		c clara.		 ] 	ifFalse: [ 		c oscura.		 ].		origin := self innerBounds origin.	self addMorph: c.	c position: ((i - 1) * c width) @ ((j - 1) * c height) + origin.	^c! !!Refer_iz methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/25/2023 11:35'!calcularReferencia: unaMatriz|i j cont fila|i:= unaMatriz numberOfRows.cont:= 0.[ i>0 ] whileTrue: [ 	Transcript show: 'col:' asString; show: j; cr.	j:= unaMatriz numberOfColumns.	fila:= cells numberOfRows.	[ j > 0 ] whileTrue: [ 		Transcript show: 'fila:' asString; show: i; cr.		((unaMatriz at:i at:j) = 1)ifTrue:[				cont:= cont + 1.			]ifFalse:[				(cont > 0)ifTrue:[					(cells at: fila at: i) label: cont asString.					cont:= 0.					fila:= fila -1.					].			].		j := j - 1	 ].		(cont > 0)ifTrue:[		(cells at: fila at: i) label: cont asString.		cont:= 0.		fila:= fila -1.		].		i:= i - 1	 ].! !Object subclass: #SelecNiv	instanceVariableNames: 'ventana botones volver custom configurar'	classVariableNames: ''	package: 'Nonograma'!!SelecNiv methodsFor: 'initialize-release' stamp: 'EscalanteThiago 11/26/2023 15:25'!closeventana close.! !!SelecNiv methodsFor: 'initialization' stamp: 'EscalanteThiago 11/26/2023 18:29'!initialize |ancho alto|botones:= Array new: 9.ventana:= SystemWindow new.1 to: 9 do: [ :x | 	botones at:x put:(BotonComun new). 	(botones at:x)label: 'Nivel ', (x asString).	ventana addMorph: (botones at:x). 	(botones at:x) mouseAction: [self seleccionar: x].	].ancho:= ((botones at:1) width) * 3.alto:= (botones at:1) height * 4.ventana extent: (200@250) + (ancho@alto).volver:= BotonComun new.volver label: 'Volver'.volver color: (Color fromHexString: '#5ba35f').volver mouseAction: [ self regresar  ].custom:= BotonComun new.custom label: 'Custom'.custom color: (Color fromHexString: '#a14347').custom mouseAction: [ self nivelCustom  ] .configurar:= BotonComun new.configurar label: 'Tamaño'.configurar color: (Color fromHexString: '#a67247').configurar mouseAction: [ self cambiarTamaño ].ventana addMorph: configurar.ventana addMorph: volver.ventana addMorph: custom.self posicionarBotones.ventana setLabel: 'Selecciona un Nivel'.ventana openInWorld.! !!SelecNiv methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 17:24'!regresar ventana close.PTitulo new.! !!SelecNiv methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 18:30'!nivelCustom|ruta nivel|ruta:= UIManager default chooseFullFileNameMatching: #('*.fuel').ruta ifNotNil:[		self close.		nivel:= Nivel new.		nivel crearNivel: (self abrir:ruta).	]! !!SelecNiv methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 15:13'!cambiarTamaño	| tamaño  |	tamaño := UIManager default		            request: 'Ingrese un tamaño para las casillas'		            initialAnswer: ''		            title: 'Tamaño para las casillas'.	[ (tamaño = '')or: [ tamaño = '0' ] ] whileTrue: [		tamaño := UIManager default			            request: 'Por favor ingrese un tamaño valido'			            initialAnswer: ''			            title: 'Tamaño para las casillas' ].			tamaño ifNotNil:[		tamaño:= tamaño asInteger.		Truco size: tamaño].! !!SelecNiv methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 14:54'!posicionarBotones|ancho alto|ancho:= (botones at:1) width.alto:= (botones at:1) height .(botones at:1) position: (ventana position) + (50@50).(botones at:2) position: ((botones at:1) position) + (ancho@0) + (50@0).(botones at:3) position: ((botones at:2) position) + (ancho@0) + (50@0).(botones at:4) position: ((botones at:1) position) + (0@alto) + (0@50).(botones at:5) position: ((botones at:2) position) + (0@alto) + (0@50).(botones at:6) position: ((botones at:3) position) + (0@alto) + (0@50).(botones at:7) position: ((botones at:4) position) + (0@alto) + (0@50).(botones at:8) position: ((botones at:5) position) + (0@alto) + (0@50).(botones at:9) position: ((botones at:6) position) + (0@alto) + (0@50).configurar position: ((botones at:7) position) + (0@alto) + (0@50).custom position: ((botones at:8) position) + (0@alto) + (0@50).volver position: ((botones at:9) position) + (0@alto) + (0@50).! !!SelecNiv methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 11:26'!numero: unNumero|string|string:= ('puzzle',(unNumero asString),'.fuel').^string ! !!SelecNiv methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 18:25'!abrir: unaRuta| object fileName stream |	fileName := unaRuta.		stream := fileName asFileReference binaryReadStream.	object := FLMaterializer materializeFrom: stream.	stream close.^object! !!SelecNiv methodsFor: 'as yet unclassified' stamp: 'EscalanteThiago 11/26/2023 15:26'!seleccionar: unNumero| object fileName stream nivel |self close.fileName:= self numero: unNumero.	stream := fileName asFileReference binaryReadStream.object := FLMaterializer materializeFrom: stream.stream close.nivel:= Nivel new.nivel crearNivel: object.! !Object subclass: #Truco	instanceVariableNames: ''	classVariableNames: 'resolver size'	package: 'Nonograma'!"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!Truco class	instanceVariableNames: ''!!Truco 