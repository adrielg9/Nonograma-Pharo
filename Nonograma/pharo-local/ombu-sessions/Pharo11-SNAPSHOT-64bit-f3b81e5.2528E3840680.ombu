			#name : #initialize,
			#protocol : #initialization,
			#sourceCode : 'initialize \r|ancho alto|\rbotones:= Array new: 9.\rventana:= SystemWindow new.\r1 to: 9 do: [ :x | \r\tbotones at:x put:(BotonComun new). \r\t(botones at:x)label: \'Nivel \', (x asString).\r\tventana addMorph: (botones at:x). \r\t(botones at:x) mouseAction: [self seleccionar: x].\r\t].\r\r\r\rancho:= ((botones at:1) width) * 3.\ralto:= (botones at:1) height * 4.\rventana extent: (200@250) + (ancho@alto).\r\r\r\rvolver:= BotonComun new.\rvolver label: \'Volver\'.\rvolver color: (Color fromHexString: \'#5ba35f\').\rcustom:= BotonComun new.\rcustom label: \'Custom\'.\rcustom color: (Color fromHexString: \'#a14347\').\rconfigurar:= BotonComun new.\rconfigurar label: \'Tamaño\'.\rconfigurar color: (Color fromHexString: \'#a67247\').\rconfigurar mouseAction: [ self cambiarTamaño ].\rventana addMorph: configurar.\rventana addMorph: volver.\rventana addMorph: custom.\rself posicionarBotones.\r\rventana setLabel: \'Selecciona un Nivel\'.\rventana openInWorld.',
