			#name : #editor,
			#protocol : #accessing,
			#sourceCode : 'editor\r|ancho alto nivel tamaño|\r\t\r\tancho := UIManager default\r\t\t            request: \'Ingrese un ancho para el tablero\'\r\t\t            initialAnswer: \'\'\r\t\t            title: \'Configurando el editor\'.\r\t[ (ancho = \'\')or: [ ancho = \'0\' ] ] whileTrue: [\r\t\tancho := UIManager default\r\t\t\t            request: \'Por favor ingrese un ancho valido\'\r\t\t\t            initialAnswer: \'\'\r\t\t\t            title: \'Configurando el editor\' ].\r\rancho ifNil: [ ^nil ].\r\ralto := UIManager default\r\t\t            request: \'Ingrese un alto para el tablero\'\r\t\t            initialAnswer: \'\'\r\t\t            title: \'Configurando el editor\'.\r\t[ (alto = \'\')or: [ alto = \'0\' ] ] whileTrue: [\r\t\talto := UIManager default\r\t\t\t            request: \'Por favor ingrese un alto valido\'\r\t\t\t            initialAnswer: \'\'\r\t\t\t            title: \'Configurando el editor\' ].\r\t\t\ralto ifNil: [ ^nil ].\r\t\t\r\t\ttamaño := UIManager default\r\t\t            request: \'Ingrese un tamaño para las casillas del tablero\'\r\t\t            initialAnswer: \'\'\r\t\t            title: \'Configurando el editor\'.\r\t[ (tamaño = \'\')or: [ tamaño = \'0\' ] ] whileTrue: [\r\t\ttamaño := UIManager default\r\t\t\t            request: \'Por favor ingrese un tamaño valido\'\r\t\t\t            initialAnswer: \'\'\r\t\t\t            title: \'Configurando el editor\' ].\r\t\t\rtamaño ifNotNil:[\r\tancho:= ancho asInteger. \r\talto:= alto asInteger.\r\ttamaño:= tamaño asInteger.\r\tnivel:= Nivel new.\r\tnivel editor: tamaño ancho: ancho  alto: alto. \r\t]\r\r\r\r',
			#stamp : 'EscalanteThiago 11/26/2023 16:41',
			#package : #Nonograma
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #PTitulo,
				#isMetaSide : false
			},
			#name : #editor,
			#protocol : #accessing,
			#sourceCode : 'editor\r|ancho alto nivel tamaño|\r\t\r\tancho := UIManager default\r\t\t            request: \'Ingrese un ancho para el tablero\'\r\t\t            initialAnswer: \'\'\r\t\t            title: \'Configurando el editor\'.\r\t[ (ancho = \'\')or: [ ancho = \'0\' ] ] whileTrue: [\r\t\tancho := UIManager default\r\t\t\t            request: \'Por favor ingrese un ancho valido\'\r\t\t\t            initialAnswer: \'\'\r\t\t\t            title: \'Configurando el editor\' ].\r\rancho ifNil: [ ^nil ].\r\ralto := UIManager default\r\t\t            request: \'Ingrese un alto para el tablero\'\r\t\t            initialAnswer: \'\'\r\t\t            title: \'Configurando el editor\'.\r\t[ (alto = \'\')or: [ alto = \'0\' ] ] whileTrue: [\r\t\talto := UIManager default\r\t\t\t            request: \'Por favor ingrese un alto valido\'\r\t\t\t            initialAnswer: \'\'\r\t\t\t            title: \'Configurando el editor\' ].\r\t\t\ralto ifNil: [ ^nil ].\r\t\t\r\t\ttamaño := UIManager default\r\t\t            request: \'Ingrese un tamaño para las casillas del tablero\'\r\t\t            initialAnswer: \'\'\r\t\t            title: \'Configurando el editor\'.\r\t[ (tamaño = \'\')or: [ tamaño = \'0\' ] ] whileTrue: [\r\t\ttamaño := UIManager default\r\t\t\t            request: \'Por favor ingrese un tamaño valido\'\r\t\t\t            initialAnswer: \'\'\r\t\t\t            title: \'Configurando el editor\' ].\r\t\t\rtamaño ifNotNil:[\r\tself close.\r\tancho:= ancho asInteger. \r\talto:= alto asInteger.\r\ttamaño:= tamaño asInteger.\r\tnivel:= Nivel new.\r\tnivel editor: tamaño ancho: ancho  alto: alto. \r\t]\r\r\r\r',
