	#tags : {
		#author : 'EscalanteThiago',
		#time : DateAndTime [ '2023-11-26T14:19:51.576-03:00' ],
		#prior : OmReference [ '42' ],
		#self : OmReference [ '43' ]
	},
	#content : EpMethodModification {
		#oldMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Nivel,
				#isMetaSide : false
			},
			#name : #'crearNivel:ancho:alto:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'crearNivel: unTamaño ancho: unAncho alto: unAlto \r\r"Creamos el tablero del tamaño"\rtablero calcularPintadas.\rtablero crearTablero: unTamaño  ancho: unAncho  altura: unAlto .\r"Creamos la referencia superior"\rref_superior:= Refer_sup new.\rref_superior crearTablero: unTamaño ancho: unAncho altura: (unAlto / 2) ceiling.\r"Creamos la referencia izquierda"\rref_izquierda := Refer_iz new.\rref_izquierda crearTablero: unTamaño ancho: (unAncho /2) ceiling altura: unAlto ceiling.\r\r"creamos botones"\rclear:= BotonComun new.\rclear label: \'Limpiar\'.\rclear mouseAction: [ tablero limpiar ].\r\rvolver := BotonComun new.\rvolver label: \'Volver\'.\rvolver color: (Color fromHexString: \'#5ba35f\').\rvolver mouseAction: [ tablero exportar. ].\r\r"creamos la ventana para poner todo lo demas dentro y posicionamos lo que creamos"\rventana:= SystemWindow new.\rventana extent: (tablero extent)+((ref_izquierda width)@(ref_superior height))+(150@100)+((clear width)@0).\rventana addMorph: tablero.\rventana addMorph: ref_izquierda.\rventana addMorph: ref_superior.\rventana addMorph: clear.\rventana addMorph: volver.\r"Posicionamos los tableros"\rtablero position: ventana position + (50@50) + ((ref_izquierda width)@(ref_superior height)).\rclear position: tablero position + ((tablero width)@0) + (50@0).\rvolver position: clear position + (0@(clear height)) + (0@20).\rref_izquierda position: ventana position + (50@50) + (0@(ref_superior height)).\rref_superior position: ventana position + (50@50) + ((ref_izquierda width)@0).\r\r"Abrimos la ventana en el mundo"\rventana setLabel: \'Nonograma\'.\rventana openInWorld.\r\r',
			#stamp : 'EscalanteThiago 11/26/2023 14:11',
			#package : #Nonograma
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Nivel,
				#isMetaSide : false
			},
			#name : #'crearNivel:ancho:alto:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'crearNivel: unTamaño ancho: unAncho alto: unAlto \r\r"Creamos el tablero del tamaño"\rtablero calcularPintadas.\rtablero crearTablero: unTamaño  ancho: unAncho  altura: unAlto .\r"Creamos la referencia superior"\rref_superior:= Refer_sup new.\rref_superior crearTablero: unTamaño ancho: unAncho altura: (unAlto / 2) ceiling.\r"Creamos la referencia izquierda"\rref_izquierda := Refer_iz new.\rref_izquierda crearTablero: unTamaño ancho: (unAncho /2) ceiling altura: unAlto ceiling.\r\r"creamos botones"\rclear:= BotonComun new.\rclear label: \'Limpiar\'.\rclear mouseAction: [ tablero limpiar ].\r\rvolver := BotonComun new.\rvolver label: \'Volver\'.\rvolver color: (Color fromHexString: \'#5ba35f\').\rvolver mouseAction: [ tablero exportar. ].\r\r"creamos la ventana para poner todo lo demas dentro y posicionamos lo que creamos"\rventana:= SystemWindow new.\rventana extent: (tablero extent)+((ref_izquierda width)@(ref_superior height))+(150@100)+((clear width)@0).\rventana addMorph: tablero.\rventana addMorph: ref_izquierda.\rventana addMorph: ref_superior.\rventana addMorph: clear.\rventana addMorph: volver.\r"Posicionamos los tableros"\rtablero position: ventana position + (50@50) + ((ref_izquierda width)@(ref_superior height)).\rclear position: tablero position + ((tablero width)@0) + (50@0).\rvolver position: clear position + (0@(clear height)) + (0@20).\rref_izquierda position: ventana position + (50@50) + (0@(ref_superior height)).\rref_superior position: ventana position + (50@50) + ((ref_izquierda width)@0).\r\r(Truco resolver) ifTrue:[\r\t\tresolver:= BotonComun new.\r\t\tresolver color: (Color fromHexString: \'#8347a6\').\r\t].\r\r"Abrimos la ventana en el mundo"\rventana setLabel: \'Nonograma\'.\rventana openInWorld.\r\r',
			#stamp : 'EscalanteThiago 11/26/2023 14:19',
			#package : #Nonograma
		}
	}
}OmEntry {
