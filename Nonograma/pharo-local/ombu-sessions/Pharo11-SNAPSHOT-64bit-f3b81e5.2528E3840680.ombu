			#sourceCode : 'editor: unTamaño ancho: unAncho alto: unAlto \r\r"Creamos el tablero del tamaño"\rtablero:= Nonograma new.\rtablero crearTablero: unTamaño  ancho: unAncho  altura: unAlto .\r\r\r"creamos botones para reinicio y exportacion"\rclear:= BotonComun new.\rclear label: \'Limpiar\'.\rclear mouseAction: [ tablero limpiar ].\r\rexport := BotonComun new.\rexport label: \'Exportar\'.\rexport mouseAction: [ tablero exportar. ].\rexport color: (Color fromHexString: \'#a14347\').\r\rvolver := BotonComun new.\rvolver label: \'Volver\'.\rvolver color: (Color fromHexString: \'#5ba35f\').\rvolver mouseAction: [ self regresar. ].\r\r\rventana:= SystemWindow new.\rventana extent: (tablero extent)+(150@100)+ ((clear width)@0).\rventana addMorph: clear.\rventana addMorph: export.\rventana addMorph: volver.\rventana addMorph: tablero.\r\r"Posicionamos los tableros"\rtablero position: ventana position + (50@50).\rclear position: ventana position + (100@50) + ((tablero width)@0).\rexport position: clear position + (0@20) + (0@(clear height)).\rvolver position: export position + (0@20) + (0@(clear height)).\r\r"Abrimos la ventana en el mundo"\rventana setLabel: \'Crea tu propio Nonograma\'.\rventana openInWorld.\r\r',
			#stamp : 'EscalanteThiago 11/26/2023 17:00',
			#package : #Nonograma
		}
	}
}OmEntry {
