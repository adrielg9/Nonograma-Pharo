			#name : #initialize,
			#protocol : #initialization,
			#sourceCode : 'initialize \r|ancho alto|\rbotones:= Array new: 9.\rventana:= SystemWindow new.\r1 to: 9 do: [ :x | \r\tbotones at:x put:(BotonComun new). \r\t(botones at:x)label: \'Nivel \', (x asString).\r\tventana addMorph: (botones at:x). \r\t].\r\r\r\rancho:= ((botones at:1) width) * 3.\ralto:= (botones at:1) height * 4.\rventana extent: (200@250) + (ancho@alto).\rancho:= (botones at:1) width.\ralto:= (botones at:1) height .\r(botones at:1) position: (ventana position) + (50@50).\r(botones at:2) position: ((botones at:1) position) + (ancho@0) + (50@0).\r(botones at:3) position: ((botones at:2) position) + (ancho@0) + (50@0).\r(botones at:4) position: ((botones at:1) position) + (0@alto) + (0@50).\r(botones at:5) position: ((botones at:2) position) + (0@alto) + (0@50).\r(botones at:6) position: ((botones at:3) position) + (0@alto) + (0@50).\r(botones at:7) position: ((botones at:4) position) + (0@alto) + (0@50).\r(botones at:8) position: ((botones at:5) position) + (0@alto) + (0@50).\r(botones at:9) position: ((botones at:6) position) + (0@alto) + (0@50).\r(botones at:1) mouseAction: [self seleccionar: 1].\r\rvolver:= BotonComun new.\rvolver label: \'Volver\'.\rvolver color: (Color fromHexString: \'#5ba35f\').\rcustom:= BotonComun new.\rcustom label: \'Custom\'.\rcustom color: (Color fromHexString: \'#a14347\').\rventana addMorph: volver.\rventana addMorph: custom.\rcustom position: ((botones at:8) position) + (0@alto) + (0@50).\rvolver position: ((botones at:9) position) + (0@alto) + (0@50).\r\rventana setLabel: \'Selecciona un Nivel\'.\rventana openInWorld.',
			#stamp : 'EscalanteThiago 11/26/2023 00:00',
			#package : #Nonograma
		},
