	#tags : {
		#author : 'EscalanteThiago',
		#time : DateAndTime [ '2023-11-26T11:40:05.011-03:00' ],
		#prior : OmReference [ '10' ],
		#self : OmReference [ '11' ]
	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Nonograma,
				#isMetaSide : false
			},
			#name : #exportar,
			#protocol : #'as yet unclassified',
			#sourceCode : 'exportar\r| object fileName stream |\r\r\tobject := (self copiarMatriz).\r\tfileName := UIManager default request: \'Ingrese un nombre para el archivo\' initialAnswer: \'\'  title:\'Nombre del archivo\' .\r\t\r\t[ fileName = \'\' ] whileTrue: [ \r\t\tfileName := UIManager default request: \'Por favor ingrese un nombre valido\' initialAnswer: \'\'  title:\'Nombre del archivo\' .\r\t ].\r\r(fileName = nil) ifFalse: [ \r\tstream := fileName asFileReference binaryWriteStream.\r\tFLSerializer serialize: object on: stream.\r\tstream close.\r\t ]\r',
			#stamp : 'EscalanteThiago 11/26/2023 11:40',
			#package : #Nonograma
		}
	}
}OmEntry {
