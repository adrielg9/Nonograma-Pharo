	#tags : {
		#author : 'EscalanteThiago',
		#time : DateAndTime [ '2023-11-26T16:45:52.722-03:00' ],
		#prior : OmReference [ '122' ],
		#self : OmReference [ '123' ]
	},
	#content : EpMethodModification {
		#oldMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Nivel,
				#isMetaSide : false
			},
			#name : #'editor:ancho:alto:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'editor: unTamaño ancho: unAncho alto: unAlto \r\r"Creamos el tablero del tamaño"\rtablero:= Nonograma new.\rtablero crearTablero: unTamaño  ancho: unAncho  altura: unAlto .\r\r\r"creamos botones para reinicio y exportacion"\rclear:= BotonComun new.\rclear label: \'Limpiar\'.\rclear mouseAction: [ tablero limpiar ].\r\rexport := BotonComun new.\rexport label: \'Exportar\'.\rexport mouseAction: [ tablero exportar. ].\r\r\rventana:= SystemWindow new.\rventana extent: (tablero extent)+(150@100)+ ((clear width)@0).\rventana addMorph: clear.\rventana addMorph: export.\rventana addMorph: tablero.\r\r"Posicionamos los tableros"\rtablero position: ventana position + (50@50).\rclear position: ventana position + (100@50) + ((tablero width)@0).\rexport position: ventana position + (100@100) + ((tablero width)@(clear height)).\r\r"Abrimos la ventana en el mundo"\rventana setLabel: \'Crea tu propio Nonograma\'.\rventana openInWorld.\r\r',
			#stamp : 'EscalanteThiago 11/26/2023 11:43',
			#package : #Nonograma
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Nivel,
				#isMetaSide : false
			},
			#name : #'editor:ancho:alto:',
			#protocol : #'as yet unclassified',
