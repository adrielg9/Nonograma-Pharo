			#sourceCode : 'colocarElementos\r\rtitulo position: self position + (50@50).\rnombre1 position: titulo position + (0@(titulo height)) + (0@20).\rnombre2 position: nombre1 position + (0@(titulo height)) + (0@20).\rnombre3 position: nombre2 position + (0@(titulo height)) + (0@20).\rnombre4 position: nombre3 position + (0@(titulo height)) + (0@20).\rvolver position: nombre4 position + (0@(titulo height)) + (0@20).',
