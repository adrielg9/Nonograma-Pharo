	#tags : {
		#author : 'EscalanteThiago',
		#time : DateAndTime [ '2023-11-26T18:49:20.656-03:00' ],
		#prior : OmReference [ '42' ],
		#self : OmReference [ '43' ]
	},
	#content : EpMethodModification {
		#oldMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Nonograma,
				#isMetaSide : false
			},
			#name : #'newCellAt:at:size:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'newCellAt: i at: j size: unTamaño\r"Create a cell for position (i,j) and add it to my on-screen\rrepresentation at the appropriate screen position. Answer the\rnew cell"\r| c origin |\r\tc := NOCell new.\r\tc setTamaño: unTamaño.\r\torigin := self innerBounds origin.\r\tself addMorph: c.\r\tc position: ((i - 1) * c width) @ ((j - 1) * c height) + origin.\r\tc mouseAction: [ \r\t\tc isOn ifTrue: [ self disminuir] \r\t\tifFalse: [ self aumentar].\r\t\tc toggleState.\r\t\t(pintadas = cont) ifTrue:[\r\t\t\t\t(matriz=(self copiarMatriz))ifTrue:[\r\t\t\t\t\t\tUIManager default alert: \'Usted ha ganado\'\r\t\t\t\t]\r\t\t\t]\r\t\t].\r\t^c',
			#stamp : 'EscalanteThiago 11/25/2023 22:54',
			#package : #Nonograma
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Nonograma,
				#isMetaSide : false
			},
			#name : #'newCellAt:at:size:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'newCellAt: i at: j size: unTamaño\r\r| c origin men |\r\tc := NOCell new.\r\tc setTamaño: unTamaño.\r\torigin := self innerBounds origin.\r\tself addMorph: c.\r\tc position: ((i - 1) * c width) @ ((j - 1) * c height) + origin.\r\tc mouseAction: [ \r\t\tc isOn ifTrue: [ self disminuir] \r\t\tifFalse: [ self aumentar].\r\t\tc toggleState.\r\t\t(pintadas = cont) ifTrue:[\r\t\t\t\t(matriz=(self copiarMatriz))ifTrue:[\r\t\t\t\t\t\tmen:= Alerta new.\r\t\t\t\t\t\tmen mensaje: \'!!Ganaste!!\'.\r\t\t\t\t]\r\t\t\t]\r\t\t].\r\t^c',
			#stamp : 'EscalanteThiago 11/26/2023 18:49',
			#package : #Nonograma
		}
	}
}OmEntry {
