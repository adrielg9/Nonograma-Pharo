			#name : #'calcularReferencia:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'calcularReferencia: unaMatriz\r|i j cont fila|\r\rfila:= cells numberOfRows.\rcont:= 0.\r\r1 to: (unaMatriz numberOfColumns) \rdo: [ j | \r\t(unaMatriz numberOfRows to: 1 by: -1)\r\t do: [ i | \r\t\t((unaMatriz at: i at:j) = 1) ifTrue:[ cont:= cont + 1]\r\t\tifFalse:[\r\t\t\t(cont > 1)ifTrue:[\r\t\t\t\t(cells at: fila at: i)\r\t\t\t\t]\r\t\t\t]\r\t\t]\r\t ]',
			#stamp : 'EscalanteThiago 11/24/2023 23:55',
			#package : #Nonograma
		}
	}
}OmEntry {
