			#name : #'newCellAt:at:size:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'newCellAt: i at: j size: unTamaño\r"Create a cell for position (i,j) and add it to my on-screen\rrepresentation at the appropriate screen position. Answer the\rnew cell"\r| c origin |\r\tc := RefCell new.\r\tc setTamaño: unTamaño.\r\t\r\t(j odd) \r\tifTrue: [ \r\t\tc clara.\r\t\t ] \r\tifFalse: [ \r\t\tc oscura.\r\t\t ].\r\t\r\torigin := self innerBounds origin.\r\tself addMorph: c.\r\tc position: ((i - 1) * c width) @ ((j - 1) * c height) + origin.\r\t^c',
			#stamp : 'EscalanteThiago 11/24/2023 19:07',
			#package : #Nonograma
		}
	}
}OmEntry {
