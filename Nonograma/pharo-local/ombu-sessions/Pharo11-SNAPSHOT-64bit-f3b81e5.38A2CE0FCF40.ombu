			#name : #'crearNivel:ancho:alto:puzzle:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'crearNivel: unTamaño ancho: unAncho alto: unAlto puzzle: unaMatriz\r\r"Creamos el tablero del tamaño"\rtablero:= Nonograma new.\rtablero crearTablero: unTamaño  ancho: unAncho  altura: unAlto .\r"Creamos la referencia superior"\rref_superior:= Refer_sup new.\rref_superior crearTablero: unTamaño ancho: unAncho altura: (unAlto / 2) ceiling.\r"Creamos la referencia izquierda"\rref_izquierda := Refer_iz new.\rref_izquierda crearTablero: unTamaño ancho: (unAncho /2) ceiling altura: unAlto ceiling.\r\r"creamos la ventana para poner todo lo demas dentro y posicionamos lo que creamos"\rventana:= SystemWindow new.\rventana extent: (tablero extent)+((ref_izquierda width)@(ref_superior height))+(100@100).\rventana addMorph: tablero.\rventana addMorph: ref_izquierda.\rventana addMorph: ref_superior.\r"Posicionamos los tableros"\rtablero position: ventana position + (50@50) + ((ref_izquierda width)@(ref_superior height)).\rref_izquierda position: ventana position + (50@50) + (0@(ref_superior height)).\rref_superior position: ventana position + (50@50) + ((ref_izquierda width)@0).\r\r"Abrimos la ventana en el mundo"\rventana setLabel: \'Nonograma\'.\rventana openInWorld.\r\r',
			#stamp : 'EscalanteThiago 11/24/2023 19:58',
			#package : #Nonograma
		}
	}
}OmEntry {
