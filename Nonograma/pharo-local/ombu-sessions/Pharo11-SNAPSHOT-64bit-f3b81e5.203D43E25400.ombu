			#name : #'calcularReferencia:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'calcularReferencia: unaMatriz\r|cont fila|\r\rTranscript show: \'Llegue1\'.\r\rfila:= cells numberOfRows.\rcont:= 0.\rTranscript show: \'Llegue2\'.\r\r1 to: (unaMatriz numberOfColumns) \rdo: [ :j | \r\tunaMatriz numberOfRows to: 1 by: -1\r\t do: [ :i | \r\t\t((unaMatriz at: i at:j) = 1) ifTrue:[ cont:= cont + 1]\r\t\tifFalse:[\r\t\t\t(cont > 0)ifTrue:[ Transcript show: \'Llegue3\'.\r\t\t\t\t(cells at: fila at: j)label: cont asString.\r\t\t\t\tfila:= fila - 1.\r\t\t\t\tTranscript show: \'Llegue4\'.\r\t\t\t\t].\r\t\t\tcont:= 0\r\t\t\t].\r\t\t].\r\tfila:= cells numberOfRows.\r\t ].',
			#stamp : 'EscalanteThiago 11/25/2023 00:24',
			#package : #Nonograma
		},
		#newMethod : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Refer_sup,
				#isMetaSide : false
			},
			#name : #'calcularReferencia:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'calcularReferencia: unaMatriz\r|i j cont fila|\r\rTranscript show: \'Llegue1\'.\r\rfila:= cells numberOfRows.\rcont:= 0.\r',
			#stamp : 'EscalanteThiago 11/25/2023 09:52',
			#package : #Nonograma
		}
	}
}OmEntry {
