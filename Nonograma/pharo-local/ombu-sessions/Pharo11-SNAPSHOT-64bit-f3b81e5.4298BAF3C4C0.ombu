			#name : #'calcularPintadas:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'calcularPintadas: unaMatriz\r\rpintadas:= 0.\r\r1 to: (unaMatriz  numberOfRows) do:[:i| \r\t1 to: (unaMatriz numberOfColumns) do: [ :j|\r\t\t\t((unaMatriz at: i at:j) = 1) ifTrue:[pintadas := pintadas + 1].\r\t\t ].\r\t].',
			#stamp : 'EscalanteThiago 11/25/2023 22:30',
			#package : #Nonograma
		}
	}
}OmEntry {
