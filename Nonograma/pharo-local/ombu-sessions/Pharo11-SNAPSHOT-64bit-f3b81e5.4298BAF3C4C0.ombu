	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #SelecNiv,
				#isMetaSide : false
			},
			#name : #'seleccionar:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'seleccionar: unNumero\r| object fileName stream |\r(unNumero = 1) ifTrue: [ fileName := \'puzzle1.fuel\'. ].\r\t"la variable stream se utiliza para leer el objeto serializado desde el archivo. \r\tLa clase FLMaterializer se utiliza para deserializar el objeto, y el objeto deserializado se almacena en la variable object."\r\t\r\tstream := fileName asFileReference binaryReadStream.\r\tobject := FLMaterializer materializeFrom: stream.\r\tstream close.\r',
			#stamp : 'EscalanteThiago 11/25/2023 23:58',
			#package : #Nonograma
		}
	}
}OmEntry {
