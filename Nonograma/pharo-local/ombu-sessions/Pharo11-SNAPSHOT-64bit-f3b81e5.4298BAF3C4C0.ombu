			#sourceCode : 'initialize \rsuper initialize.\rself color: (Color fromHexString: \'#3d6574\' ).\rself borderColor: (Color fromHexString: \'#404040\' ).\rself borderWidth: 3.\rfuenteActual := (StrikeFont familyName: \'Bitmap DejaVu Sans\' size: 20).\rself label: \'\' font: fuenteActual.\rself extent: 100@60',
