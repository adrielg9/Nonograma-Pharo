			#protocol : #initialization,
			#sourceCode : 'initialize \r|fuente|\r\tsuper initialize.\r\tfuente := StandardFonts menuFont.\r\tself label: \'16\' font: fuente.\r\tself label fontName: \'Bitmap DejaVu Sans\'  size: 40. \r\tself borderWidth: 2.\r\tself extent: 50@50.\r\t"bounds:= 200 @ 200 corner: 250 @ 250."\r\tself enabled: false.\r\tself useSquareCorners.',
