	},
	#content : EpMethodAddition {
		#method : RGMethodDefinition {
			#annotations : IdentityDictionary {
				#className : #Nonograma,
				#isMetaSide : false
			},
			#name : #'crearTablero:ancho:altura:',
			#protocol : #initialization,
			#sourceCode : 'crearTablero: unTamaño ancho: unaAltura altura: unAncho\r| sampleCell width height |\r\tsampleCell := NOCell new.\r\tsampleCell setTamaño: unTamaño.\r\twidth := sampleCell width.\r\theight := sampleCell height.\r\tself bounds: (unTamaño @ unTamaño extent: (width * unaAltura) @ (height * unAncho) + (2 * self\r\tborderWidth)).\r\tcells := Array2D rows: unaAltura  columns: unAncho tabulate: [ :i :j | self newCellAt: i at:\r\tj size: unTamaño]',
			#stamp : 'ThiagoEscalante 11/18/2023 22:33',
			#package : #Nonograma
		}
	}
}OmEntry {
	#tags : {
