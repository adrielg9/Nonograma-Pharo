			#name : #'numero:font:',
			#protocol : #'as yet unclassified',
			#sourceCode : 'numero: aString font: aFont\r\r\tnumero ifNotNil: [numero delete].\r\tnumero := TextMorph new.\r\tnumero contents: aString.\r\tnumero extent: self extent.\r\tnumero position: self center.\r\tnumero centered.\r\t"numero setContainer: self."\r\t"self extent: (numero width + 6) @ (numero height + 6).\r\tnumero position: self center - (numero extent // 2)."\r\tself addMorph: numero.\r\tnumero lock',
