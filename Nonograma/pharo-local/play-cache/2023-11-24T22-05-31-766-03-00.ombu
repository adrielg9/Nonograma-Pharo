	#content : '| object fileStream |\r\r"Create an object to be stored"\robject := #(1 2 \'Hello\' $a).\r\r"Open a file for writing"\rfileStream := FileStream fileNamed: \'objectFile.txt\' mode: WriteStream mode.\r\r"Store the object in the file"\robject storeOn: fileStream.\r\r"Close the file"\rfileStream close.'
