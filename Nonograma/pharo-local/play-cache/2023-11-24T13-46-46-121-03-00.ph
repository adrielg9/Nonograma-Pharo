nono:= Nonograma new.nono crearTablero: 30  ancho: 16  altura: 16 .nono openInWorld.ventana:= SystemWindow new.ventana openInWorld.ventana extent: (100@50).ventana addMorph: nono.ventana extent: (nono extent + (100@50)).nono position: ventana position + (50@50).ventana setLabel: 'Nonograma'.prueba:= RefCell new.prueba openInWorld.prueba clara.nono:= Refer_sup new.nono crearTablero: 50  ancho: 16  altura: 16 .nono openInWorld.ventana:= SystemWindow new.ventana openInWorld.ventana addMorph: nono.ventana extent: (nono extent + (100@100)).nono position: ventana position + (50@50).ventana setLabel: 'Prueba de referencia'.