| object fileName stream |	fileName := 'puzzle1.fuel'.	"la variable stream se utiliza para leer el objeto serializado desde el archivo. 	La clase FLMaterializer se utiliza para deserializar el objeto, y el objeto deserializado se almacena en la variable object."		stream := fileName asFileReference binaryReadStream.	object := FLMaterializer materializeFrom: stream.	stream close.	Transcript show: object.