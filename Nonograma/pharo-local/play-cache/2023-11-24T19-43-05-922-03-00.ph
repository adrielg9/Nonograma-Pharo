unTamaño:= 20.unAncho:= 16.unAlto:= 16tablero:= Nonograma new.tablero crearTablero: unTamaño  ancho: unAncho  altura: unAlto .ref_superior:= Refer_sup new.ref_superior crearTablero: unTamaño ancho: (unAncho / 2) ceiling altura: unAlto.ref_izquierda := Refer_iz new.ref_izquierda crearTablero: unTamaño ancho: unAncho altura: (unAlto / 2) ceiling.ventana:= SystemWindow new.ventana extent: (tablero extent)+((ref_izquierda width)@(ref_superior height))+(100@100).ventana addMorph: tablero.ventana addMorph: ref_izquierda.ventana addMorph: ref_superior.